PORT=8787
HERMES_API_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=your-hermes-api-server-key
HERMES_HOME=C:\Users\eceptadmin\AppData\Local\hermes
# Optional override:
# HERMES_PYTHON=C:\Users\eceptadmin\AppData\Local\hermes\hermes-agent\.venv\Scripts\python.exe
CORS_ORIGIN=http://localhost:5173
LOG_DIR=./logs

# Public URL Hermes uses to POST cron results back to this portal.
# Must be reachable from the Hermes host (not loopback if Hermes is remote).
PORTAL_PUBLIC_BASE_URL=http://127.0.0.1:8787

# Shared HMAC secret for Hermes → portal cron webhooks.
# Must match CRON_WEBHOOK_SECRET (or cron.webhook.secret) on the Hermes agent.
HERMES_WEBHOOK_SECRET=change-me-shared-webhook-secret
